{
  "name": "@fedify/hollo",
  "description": "Federated single-user microblogging software",
  "version": "0.9.6-satone",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "skills-npm || true",
    "prod": "pnpm run migrate && node --env-file-if-exists=.env --dns-result-order=ipv6first dist/bin/server.js",
    "dev": "pnpm run migrate && pnpm run uno:build && concurrently -k -n uno,app -c blue,green \"pnpm run uno:watch\" \"tsx watch --env-file-if-exists=.env --dns-result-order=ipv6first bin/server.ts\"",
    "worker": "NODE_TYPE=worker node --env-file-if-exists=.env --dns-result-order=ipv6first dist/bin/server.js",
    "list:routes": "tsx --env-file-if-exists=.env bin/routes.ts",
    "measure:memory": "node --expose-gc --import tsx --env-file-if-exists=.env scripts/measure-memory.ts",
    "uno:build": "unocss \"src/**/*.{tsx,ts}\" -o src/public/uno.css",
    "uno:watch": "unocss \"src/**/*.{tsx,ts}\" -o src/public/uno.css --watch",
    "build": "pnpm run uno:build && tsdown",
    "test": "pnpm run migrate:test && vitest",
    "test:ci": "vitest",
    "typecheck": "tsgo --noEmit",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "lint:github": "oxlint --format=github .",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run fmt:check",
    "check:ci": "pnpm run typecheck && pnpm run lint:github && pnpm run fmt:check",
    "check:coverage": "pnpm run migrate:test && vitest --coverage",
    "migrate": "drizzle-kit migrate",
    "migrate:test": "dotenvx run -f .env.test -- drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate",
    "rebuild-timelines": "tsx --env-file-if-exists=.env scripts/rebuild-timelines.ts"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.1037.0",
    "@fedify/debugger": "^2.2.4",
    "@fedify/fedify": "^2.2.4",
    "@fedify/hono": "^2.2.4",
    "@fedify/markdown-it-hashtag": "~0.3.0",
    "@fedify/markdown-it-mention": "~0.3.0",
    "@fedify/postgres": "^2.2.4",
    "@fedify/vocab": "^2.2.4",
    "@fedify/webfinger": "^2.2.4",
    "@hexagon/base64": "^2.0.4",
    "@hono/node-server": "^1.19.13",
    "@hono/zod-validator": "^0.7.6",
    "@js-temporal/polyfill": "^0.5.0",
    "@logtape/drizzle-orm": "~2.1.0",
    "@logtape/file": "~2.1.0",
    "@logtape/logtape": "~2.1.0",
    "@logtape/sentry": "~2.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@sentry/core": "^10.51.0",
    "@sentry/node": "^10.51.0",
    "@shikijs/markdown-it": "^4.0.2",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@supercharge/promise-pool": "^3.2.0",
    "adm-zip": "^0.5.16",
    "argon2": "^0.44.0",
    "cheerio": "^1.2.0",
    "cssfilter": "^0.0.11",
    "csv-writer-portable": "^1.7.6",
    "drizzle-kit": "1.0.0-rc.2",
    "drizzle-orm": "1.0.0-rc.2",
    "es-toolkit": "^1.46.1",
    "file-type": "^22.0.1",
    "flydrive": "^2.0.0",
    "hono": "^4.12.18",
    "iso-639-1": "^3.1.5",
    "markdown-it": "^14.1.1",
    "markdown-it-replace-link": "^1.2.2",
    "mime": "^4.1.0",
    "neat-csv": "^7.0.0",
    "open-graph-scraper": "^6.11.0",
    "otpauth": "^9.5.1",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "semver": "^7.8.0",
    "sharp": "^0.34.5",
    "ssrfcheck": "^1.4.0",
    "tsx": "^4.21.0",
    "uuidv7-js": "^1.1.4",
    "x-forwarded-fetch": "^0.2.0",
    "xss": "^1.0.15",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@fedify/lint": "^2.2.4",
    "@iconify-json/lucide": "^1.2.104",
    "@reporters/github": "^1.13.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/adm-zip": "^0.5.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/semver": "^7.7.1",
    "@typescript/native-preview": "7.0.0-dev.20260510.1",
    "@unocss/cli": "^66.6.8",
    "@vitest/coverage-v8": "3.1.4",
    "concurrently": "^9.2.1",
    "linkedom": "^0.18.12",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.65.0",
    "skills-npm": "^1.1.1",
    "timekeeper": "^2.3.1",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "unocss": "^66.6.8",
    "vitest": "^3.1.4"
  },
  "packageManager": "pnpm@9.15.1+sha512.1acb565e6193efbebda772702950469150cf12bcc764262e7587e71d19dc98a423dff9536e57ea44c49bdf790ff694e83c27be5faa23d67e0c033b583be4bfcf",
  "pnpm": {
    "overrides": {
      "fast-xml-parser@<4.5.5": "^4.5.5",
      "fast-xml-parser@>=5.0.0 <5.7.0": "^5.7.0"
    }
  }
}
