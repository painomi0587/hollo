{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 80,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "sortPackageJson": false,
  "sortImports": true,
  "ignorePatterns": [
    ".agents/**/*",
    ".github/**/*",
    "**/*.md",
    "**/*.mdx",
    "docs/.astro/**/*",
    "docs/**/*",
    "docs/dist/**/*",
    "docs/node_modules/**/*",
    "drizzle/**/*",
    "node_modules/**/*",
    "pnpm-workspace.yaml",
    "src/public/**/*"
  ]
}
